rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function ownUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserProfile() {
      return signedIn() && exists(ownUserPath());
    }

    function userProfile() {
      return get(ownUserPath());
    }

    function isAdmin() {
      return hasUserProfile()
        && userProfile().data.role == "admin";
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function keepsExistingRole() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(["role"]);
    }

    function createsStudentProfile(userId) {
      return isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role == "student";
    }

    function isPublished() {
      return resource.data.status == "Published"
        || resource.data.status == "published";
    }

    match /users/{userId} {
      allow create: if createsStudentProfile(userId) || isAdmin();
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow update: if isAdmin() || (isOwner(userId) && keepsExistingRole());
      allow delete: if isAdmin();
    }

    match /roadmaps/{roadmapId} {
      allow read: if isAdmin() || (signedIn() && isPublished());
      allow create, update, delete: if isAdmin();
    }

    match /roadmapStages/{stageId} {
      allow read: if isAdmin() || (signedIn() && resource.data.status != "Archived");
      allow create, update, delete: if isAdmin();
    }

    match /roadmapLessons/{lessonId} {
      allow read: if isAdmin() || (signedIn() && resource.data.status == "Published");
      allow create, update, delete: if isAdmin();
    }

    match /skills/{skillId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /studentProgress/{progressId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /opportunities/{opportunityId} {
      allow read: if isAdmin() || (signedIn() && isPublished());
      allow create, update, delete: if isAdmin();
    }

    match /savedOpportunities/{savedId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if signedIn()
        && resource.data.userId == request.auth.uid;
      allow list: if signedIn();
    }

    match /resources/{resourceId} {
      allow read: if isAdmin() || (signedIn() && isPublished());
      allow create, update, delete: if isAdmin();
    }

    match /stories/{storyId} {
      allow read: if isAdmin() || isPublished();
      allow create, update, delete: if isAdmin();
    }

    match /newsletterSubscribers/{subscriberId} {
      function validNewsletterSubscription() {
        return request.resource.data.keys().hasOnly([
          "email", "consent", "status", "source", "createdAt"
        ])
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 254
        && request.resource.data.email.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$')
        && request.resource.data.consent == true
        && request.resource.data.status == "subscribed"
        && request.resource.data.source is string
        && request.resource.data.source.size() <= 180
        && request.resource.data.createdAt == request.time;
      }

      allow create: if validNewsletterSubscription();
      allow update: if isAdmin()
        || (validNewsletterSubscription()
          && request.resource.data.email == resource.data.email);
      allow read, delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if isAdmin() || isPublished();
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == "published"
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 160
        && request.resource.data.category is string
        && request.resource.data.programme is string
        && request.resource.data.date is string
        && request.resource.data.time is string
        && request.resource.data.location is string
        && request.resource.data.organizer is string
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() <= 2000;
      allow update: if isAdmin()
        || (signedIn()
          && resource.data.createdBy == request.auth.uid
          && request.resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin()
        || (signedIn() && resource.data.createdBy == request.auth.uid);
    }

    match /eventRegistrations/{registrationId} {
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.eventId is string
        && request.resource.data.status == "registered";
      allow read, delete: if signedIn()
        && (resource.data.createdBy == request.auth.uid || isAdmin());
      allow update: if signedIn()
        && (resource.data.createdBy == request.auth.uid || isAdmin())
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.eventId == resource.data.eventId
        && request.resource.data.status == "registered";
    }

    match /community/{postId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /communityGroups/{groupId} {
      allow get, list: if signedIn();
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAdmin()
        || (signedIn() && resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow get, list: if signedIn();
        allow create: if signedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.userEmail == request.auth.token.email
          && request.resource.data.type in ["text", "file", "voice", "system"]
          && request.resource.data.text.size() <= 1000;
        allow update, delete: if isAdmin()
          || (signedIn() && resource.data.userId == request.auth.uid);
      }
    }

    match /marketplace/{listingId} {
      allow read: if isAdmin() || (signedIn() && isPublished());
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /marketplace_listings/{listingId} {
      allow read: if resource.data.status == "Published" || isAdmin();
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == "Published";
      allow update, delete: if isAdmin()
        || (signedIn() && resource.data.createdBy == request.auth.uid);
    }

    match /partner_profiles/{profileId} {
      allow read: if resource.data.status == "Published" || isAdmin();
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == "Published";
      allow update, delete: if isAdmin()
        || (signedIn() && resource.data.createdBy == request.auth.uid);
    }

    match /business_discussions/{discussionId} {
      allow read: if resource.data.status == "Published" || isAdmin();
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == "Published";
      allow update, delete: if isAdmin()
        || (signedIn() && resource.data.createdBy == request.auth.uid);
    }

    match /community_groups/{groupId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isAdmin()
        || (signedIn() && resource.data.createdBy == request.auth.uid);
    }

    match /group_messages/{messageId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isAdmin()
        || (signedIn() && resource.data.createdBy == request.auth.uid);
    }

    match /announcements/{announcementId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
